@page
@using System.Security.Claims
@model IndexModel
@{
    ViewData["Title"] = "Home";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="hero-section animate-fade-in">
    <div class="container">
        <h1 class="hero-title">Discover Stories & Ideas</h1>
        <p class="lead text-muted mb-5 mx-auto" style="max-width: 600px;">
            A place for creative minds to share their thoughts, learn from others, and grow together in a community of passionate writers.
        </p>
        @if (!User.Identity.IsAuthenticated)
        {
            <div class="d-flex justify-content-center gap-3">
                <a asp-page="/Register" class="btn btn-premium px-5 py-3">Start Writing</a>
                <a asp-page="/Login" class="btn btn-outline-primary border-2 rounded-4 px-5 py-3 fw-bold">Sign In</a>
            </div>
        }
    </div>
</div>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Latest Stories</h2>
        <div class="text-muted">Explore what's new</div>
    </div>

    <div class="row g-4">
        @if (Model.listOfBlogs != null && Model.listOfBlogs.Any())
        {
            @foreach (var blog in Model.listOfBlogs)
            {
                <div class="col-md-4">
                    <div class="premium-card h-100 p-4 d-flex flex-column">
                        <div class="mb-3">
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3 py-2">
                                @blog.category
                            </span>
                        </div>
                        <h3 class="h4 fw-bold mb-3">@blog.title</h3>
                        <p class="text-muted flex-grow-1">
                            @(blog.blogPost?.Length > 150 ? blog.blogPost.Substring(0, 147) + "..." : blog.blogPost)
                        </p>
                        <hr class="my-4 opacity-10">
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center">
                                <div class="bg-secondary-subtle rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                    <span class="text-secondary small fw-bold">@blog.blogger?[0]</span>
                                </div>
                                <span class="small fw-600">@blog.blogger</span>
                            </div>
                            <a asp-page="/BlogDetails" asp-route-id="@blog.blogId" class="btn btn-link text-primary p-0 text-decoration-none fw-bold small">Read More →</a>
                            @if (User.Identity.IsAuthenticated && currentUserId == blog.bloggerId)
                            {
                                <div class="d-flex gap-2">
                                    <a asp-page="/EditBlog" asp-route-id="@blog.blogId" class="btn btn-outline-primary btn-sm rounded-pill px-3">Edit</a>
                                    <a asp-page="/DeleteBlog" asp-route-id="@blog.blogId" class="btn btn-outline-danger btn-sm rounded-pill px-3">Delete</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="premium-card p-5">
                    <h3 class="text-muted">No stories yet.</h3>
                    <p>Be the first to share your thoughts!</p>
                    <a asp-page="/CreateBlog" class="btn btn-premium mt-3">Write a Blog</a>
                </div>
            </div>
        }
    </div>
</div>
